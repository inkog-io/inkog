result = crew.kickoff()
`

	findings, err := detector.Detect("test.py", []byte(code))
	if err != nil {
		t.Fatalf("Detector returned error: %v", err)
	}

	if len(findings) == 0 {
		t.Errorf("Expected to find CrewAI endless delegation loop, but found 0 findings")
	}
}

// TestRecursiveToolCallingInterfaceImplementation verifies the detector implements the interface correctly
func TestRecursiveToolCallingInterfaceImplementation(t *testing.T) {
	detector := NewRecursiveToolCallingDetectorV2Clean()

	// Check Name() method
	name := detector.Name()
	if name != "recursive_tool_calling_v2" {
		t.Errorf("Expected Name() to return 'recursive_tool_calling_v2', got '%s'", name)
	}

	// Check GetPattern() method
	pattern := detector.GetPattern()
	if pattern.ID != "recursive_tool_calling_v2" {
		t.Errorf("Expected pattern ID 'recursive_tool_calling_v2', got '%s'", pattern.ID)
	}
	if pattern.Severity != "CRITICAL" {
		t.Errorf("Expected CRITICAL severity, got '%s'", pattern.Severity)
	}
	if pattern.CVSS != 8.2 {
		t.Errorf("Expected CVSS 8.2, got %v", pattern.CVSS)
	}

	// Check GetConfidence() method
	confidence := detector.GetConfidence()
	if confidence <= 0 || confidence > 1.0 {
		t.Errorf("Expected confidence between 0 and 1, got %v", confidence)
	}
}

