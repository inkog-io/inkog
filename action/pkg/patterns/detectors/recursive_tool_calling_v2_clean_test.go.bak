	if len(findings) > 0 && findings[0].Severity != "CRITICAL" {
		t.Errorf("Expected CRITICAL severity, got %s", findings[0].Severity)
	}
}

// TestRecursiveToolCallingWithBreakShouldNotFlag tests that loops with breaks are not flagged
func TestRecursiveToolCallingWithBreakShouldNotFlag(t *testing.T) {
	detector := NewRecursiveToolCallingDetectorV2Clean()

	code := `
iterations = 0
while True:
    result = agent.run(prompt)
    iterations += 1
    if iterations >= 10:
        break
    if result.get("success"):
        break
`

	findings, err := detector.Detect("test.py", []byte(code))
	if err != nil {
		t.Fatalf("Detector returned error: %v", err)
	}

	if len(findings) > 0 {
		t.Errorf("Expected no findings for loop with break, but found %d", len(findings))
	}
}

