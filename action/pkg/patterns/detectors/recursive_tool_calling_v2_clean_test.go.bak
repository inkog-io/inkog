// TestRecursiveToolCallingDataProcessorNames tests that data processor names get reduced confidence
func TestRecursiveToolCallingDataProcessorNames(t *testing.T) {
	detector := NewRecursiveToolCallingDetectorV2Clean()

	code := `
def map_function(items):
    if items:
        return [process(items[0])] + map_function(items[1:])
    return []
`

	findings, err := detector.Detect("test.py", []byte(code))
	if err != nil {
		t.Fatalf("Detector returned error: %v", err)
	}

	// Data processor patterns (map, filter, reduce, etc.) should have lower confidence
	if len(findings) > 0 && findings[0].Confidence > 0.60 {
		t.Logf("Info: Data processor recursive call has confidence %v (expected lower due to pattern)", findings[0].Confidence)
	}
}

// TestRecursiveToolCallingRealCVELangChainSitemap tests LangChain CVE pattern
func TestRecursiveToolCallingRealCVELangChainSitemap(t *testing.T) {
	detector := NewRecursiveToolCallingDetectorV2Clean()

	// Simulated LangChain SitemapLoader infinite recursion CVE-2024-2965
	code := `
from langchain.document_loaders import SitemapLoader

def process_url(url):
    loader = SitemapLoader(url)
    docs = loader.load()
    for doc in docs:
        # Recursive call without proper termination!
        child_docs = process_url(doc.url)
        all_docs.extend(child_docs)
    return all_docs
`

	findings, err := detector.Detect("test.py", []byte(code))
	if err != nil {
		t.Fatalf("Detector returned error: %v", err)
	}

	if len(findings) == 0 {
		t.Errorf("Expected to find LangChain SitemapLoader recursion CVE, but found 0 findings")
	}
}

