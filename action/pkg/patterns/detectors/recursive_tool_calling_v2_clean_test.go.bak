result = agent1.run(prompt)
`

	findings, err := detector.Detect("test.py", []byte(code))
	if err != nil {
		t.Fatalf("Detector returned error: %v", err)
	}

	if len(findings) == 0 {
		t.Errorf("Expected to find agent delegation loop, but found 0 findings")
	}
}

