func TestRecursiveToolCallingDetectorV2_AutoGenConversationLoop(t *testing.T) {
	detector := NewRecursiveToolCallingDetectorV2()

	code := `
assistant = AutoGenAgent("Assistant")
user = AutoGenAgent("User")

while True:
    msg = assistant.step()
    if msg.content.endswith("DONE"):
        break
    user.receive(msg)
    assistant.receive(user.last_message())
`

	findings, err := detector.Detect("autogen_conversation.py", []byte(code))
	if err != nil {
		t.Fatalf("Unexpected error: %v", err)
	}

	// While True loop with agent steps, but has break condition
	if len(findings) > 0 {
		if findings[0].Severity != "HIGH" && findings[0].Severity != "MEDIUM" {
			t.Logf("AutoGen loop found with severity %s", findings[0].Severity)
		}
	}
}

func TestRecursiveToolCallingDetectorV2_AutoGenWithRoundLimit(t *testing.T) {
	detector := NewRecursiveToolCallingDetectorV2()

	code := `
MAX_ROUNDS = 10
for round in range(MAX_ROUNDS):
    msg = assistant.step()
    if msg.content.endswith("DONE"):
        break
    user.receive(msg)
    assistant.receive(user.last_message())
`

	findings, err := detector.Detect("autogen_safe.py", []byte(code))
	if err != nil {
		t.Fatalf("Unexpected error: %v", err)
	}

	// For loop with finite range should be safe
	for _, f := range findings {
		if f.Severity == "CRITICAL" {
			t.Errorf("For loop with finite range should not be CRITICAL")
		}
	}
}

