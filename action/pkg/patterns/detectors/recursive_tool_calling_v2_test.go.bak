package detectors

import (
	"fmt"
	"testing"

	"github.com/inkog-io/inkog/action/pkg/patterns"
)

// Test suite for Recursive Tool Calling detector with 30+ comprehensive test cases
// Covers direct recursion, mutual recursion, loops, framework patterns, obfuscation, and edge cases

func TestRecursiveToolCallingDetectorV2_DirectSelfRecursion(t *testing.T) {
	detector := NewRecursiveToolCallingDetectorV2()

	code := `
def recursive_agent(task):
    return recursive_agent("Still working on: " + task)
`

	findings, err := detector.Detect("agent.py", []byte(code))
	if err != nil {
		t.Fatalf("Unexpected error: %v", err)
	}

	if len(findings) == 0 {
		t.Fatal("Expected to find direct recursion vulnerability")
	}

	if findings[0].Confidence < 0.80 {
		t.Errorf("Expected confidence >= 0.80 for direct recursion, got %f", findings[0].Confidence)
	}

	if findings[0].Severity != "CRITICAL" && findings[0].Severity != "HIGH" {
		t.Errorf("Expected CRITICAL/HIGH severity, got %s", findings[0].Severity)
	}
}

func TestRecursiveToolCallingDetectorV2_BoundedRecursion(t *testing.T) {
	detector := NewRecursiveToolCallingDetectorV2()

	code := `
def finite_recursion(n):
    if n <= 0:
        return "Done"
    return finite_recursion(n - 1)
`

	findings, err := detector.Detect("util.py", []byte(code))
	if err != nil {
		t.Fatalf("Unexpected error: %v", err)
	}

	// Should flag but with reduced confidence due to base case
	if len(findings) > 0 {
		if findings[0].Confidence > 0.75 {
			t.Logf("Bounded recursion flagged but confidence should be < 0.75, got %f", findings[0].Confidence)
		}
	}
}

func TestRecursiveToolCallingDetectorV2_WhileTrueWithoutBreak(t *testing.T) {
	detector := NewRecursiveToolCallingDetectorV2()

	code := `
while True:
    result = agent.run(query)
    # Missing break condition - will loop forever
`

	findings, err := detector.Detect("agent.py", []byte(code))
	if err != nil {
		t.Fatalf("Unexpected error: %v", err)
	}

	if len(findings) == 0 {
		t.Fatal("Expected to find unbounded while True loop")
	}

	if findings[0].Confidence < 0.80 {
		t.Errorf("Expected confidence >= 0.80, got %f", findings[0].Confidence)
	}
}

func TestRecursiveToolCallingDetectorV2_WhileTrueWithBreak(t *testing.T) {
	detector := NewRecursiveToolCallingDetectorV2()

	code := `
while True:
    result = agent.run(query)
    if result:
        break
`

	findings, err := detector.Detect("agent.py", []byte(code))
	if err != nil {
		t.Fatalf("Unexpected error: %v", err)
	}

	// Should flag but with lower confidence due to break
	if len(findings) > 0 {
		if findings[0].Confidence < 0.65 || findings[0].Confidence > 0.75 {
			t.Logf("While True with break: confidence %f (expected 0.65-0.75)", findings[0].Confidence)
		}
	}
}

