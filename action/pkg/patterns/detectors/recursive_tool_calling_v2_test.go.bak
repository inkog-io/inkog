		if f.Severity == "CRITICAL" {
			t.Errorf("Data processing recursion should not be CRITICAL, got %s", f.Severity)
		}
	}
}

func TestRecursiveToolCallingDetectorV2_TreeTraversal(t *testing.T) {
	detector := NewRecursiveToolCallingDetectorV2()

	code := `
def walk_tree(node):
    if node is None:
        return
    process(node)
    for child in node.children:
        walk_tree(child)
`

	findings, err := detector.Detect("tree.py", []byte(code))
	if err != nil {
		t.Fatalf("Unexpected error: %v", err)
	}

	// Tree traversal should not be flagged as HIGH risk
	for _, f := range findings {
		if f.Confidence > 0.75 {
			t.Logf("Tree traversal: confidence %f (should be low)", f.Confidence)
		}
	}
}

func TestRecursiveToolCallingDetectorV2_SelfAskWithoutTermination(t *testing.T) {
	detector := NewRecursiveToolCallingDetectorV2()

	code := `
def self_ask_agent(question):
    answer = llm(question)
    if needs_clarification(answer):
        sub_answer = self_ask_agent(generate_subquestion(question))
        return combine(answer, sub_answer)
    return answer
`

	findings, err := detector.Detect("self_ask.py", []byte(code))
	if err != nil {
		t.Fatalf("Unexpected error: %v", err)
	}

	// Should flag direct recursion but base case might mitigate
	if len(findings) > 0 {
		t.Logf("Self-ask recursion: confidence %f", findings[0].Confidence)
	}
}

