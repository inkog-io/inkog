func TestRecursiveToolCallingDetectorV2_LangChainCVE202429(t *testing.T) {
	detector := NewRecursiveToolCallingDetectorV2()

	code := `
from langchain.document_loaders import SitemapLoader

def parse_sitemap(url):
    # CVE-2024-2965: parse_sitemap calls itself on sitemap URLs that reference themselves
    loader = SitemapLoader(url)
    docs = loader.load()  # Can cause infinite recursion if sitemap references itself
    return docs
`

	findings, err := detector.Detect("sitemap_loader.py", []byte(code))
	if err != nil {
		t.Fatalf("Unexpected error: %v", err)
	}

	// Should detect potential CVE-2024-2965 pattern
	if len(findings) > 0 {
		t.Logf("CVE-2024-2965 pattern detection: %d findings", len(findings))
	}
}

