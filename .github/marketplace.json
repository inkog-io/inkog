  "inputs": {
    "path": {
      "description": "Directory to scan for security vulnerabilities",
      "required": false,
      "default": "."
    },
    "risk-threshold": {
      "description": "Risk severity threshold to fail on",
      "required": false,
      "default": "high",
      "options": ["low", "medium", "high", "critical"]
    },
    "framework": {
      "description": "Framework to detect",
      "required": false,
      "default": "auto-detect",
      "options": ["auto-detect", "langchain", "crewai", "autogen"]
    },
    "json-report": {
      "description": "Path to output JSON report file",
      "required": false,
      "default": ""
    }
  },

  "outputs": {
    "risk-score": {
      "description": "Overall risk score (0-100)"
    },
    "findings-count": {
      "description": "Total number of security findings"
    },
    "high-risk-count": {
      "description": "Number of high-risk and critical findings"
    },
    "report-path": {
      "description": "Path to generated JSON report"
    }
