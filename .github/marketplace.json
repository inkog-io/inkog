        {
          "id": "sql_injection_via_llm",
          "name": "SQL Injection via LLM",
          "cwe": ["CWE-89", "CWE-94"],
          "severity": "CRITICAL",
          "confidence": "85%"
        },
        {
          "id": "unvalidated_code_execution",
          "name": "Unvalidated Code Execution",
          "cwe": ["CWE-95", "CWE-94"],
          "severity": "CRITICAL",
          "confidence": "90%"
        },
        {
          "id": "missing_human_oversight",
          "name": "Missing Human Oversight",
          "cwe": ["CWE-99", "CWE-674"],
          "severity": "HIGH",
          "confidence": "75%"
        },
        {
          "id": "cross_tenant_data_leakage",
          "name": "Cross-Tenant Data Leakage",
          "cwe": ["CWE-284", "CWE-862"],
          "severity": "CRITICAL",
          "confidence": "82%"
        }
      ]
    }
