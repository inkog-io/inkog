  "patterns": {
    "tier1": {
      "name": "Foundation Patterns",
      "count": 4,
      "patterns": [
        {
          "id": "hardcoded_credentials",
          "name": "Hardcoded Credentials",
          "cwe": ["CWE-798", "CWE-259"],
          "severity": "CRITICAL",
          "confidence": "98%"
        },
        {
          "id": "prompt_injection",
          "name": "Prompt Injection",
          "cwe": ["CWE-94", "CWE-95"],
          "severity": "HIGH",
          "confidence": "90%"
        },
        {
          "id": "infinite_loops",
          "name": "Infinite Loops & Recursion",
          "cwe": ["CWE-835", "CWE-674"],
          "severity": "HIGH",
          "confidence": "95%"
        },
        {
          "id": "unsafe_env_access",
          "name": "Unsafe Environment Access",
          "cwe": ["CWE-665"],
          "severity": "MEDIUM",
          "confidence": "92%"
        }
      ]
    },
    "tier2": {
      "name": "Resource Exhaustion Patterns",
      "count": 5,
      "patterns": [
        {
          "id": "token_bombing",
          "name": "Token Bombing",
          "cwe": ["CWE-400", "CWE-770"],
          "severity": "CRITICAL",
          "confidence": "88%"
        },
        {
          "id": "recursive_tool_calling",
          "name": "Recursive Tool Calling",
          "cwe": ["CWE-674", "CWE-835"],
          "severity": "CRITICAL",
          "confidence": "88%"
        },
        {
          "id": "context_accumulation",
          "name": "Context Window Accumulation",
          "cwe": ["CWE-770", "CWE-400"],
          "severity": "HIGH",
          "confidence": "80%"
        },
        {
          "id": "missing_rate_limits",
          "name": "Missing Rate Limits",
          "cwe": ["CWE-400", "CWE-770"],
          "severity": "HIGH",
          "confidence": "80%"
        },
        {
          "id": "rag_over_fetching",
          "name": "RAG Over-Fetching",
          "cwe": ["CWE-770", "CWE-400"],
          "severity": "HIGH",
          "confidence": "85%"
        }
      ]
    },
    "tier3": {
      "name": "Data & Execution Patterns",
      "count": 6,
      "patterns": [
        {
          "id": "logging_sensitive_data",
          "name": "Logging Sensitive Data",
          "cwe": ["CWE-532", "CWE-209"],
          "severity": "HIGH",
          "confidence": "82%"
        },
        {
          "id": "output_validation_failures",
          "name": "Output Validation Failures",
          "cwe": ["CWE-74", "CWE-95"],
          "severity": "CRITICAL",
          "confidence": "78%"
